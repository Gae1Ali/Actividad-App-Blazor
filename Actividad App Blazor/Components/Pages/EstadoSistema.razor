@page "/EstadoSistema"
@rendermode InteractiveServer
<div class="container mt-4">
    <h2>Visor de Estado del Sistema</h2>

    <div class="row">
        <div class="col-md-6 border-end">
            <h4>1. Control Manual</h4>
            <div class="p-3 bg-light rounded shadow-sm">
                <label class="form-label">Escribe el código:</label>
                <input type="number" @bind="valorInput" class="form-control mb-2" style="width: 150px;" />
                
                <button class="btn btn-primary" @onclick="ActualizarVisor">
                    Actualizar Estado
                </button>
            </div>

            <div class="mt-4">
                <h6>Resultado:</h6>
                @* Solo cambia cuando el botón se presiona *@
                <EstadoComponente CodigoEstado="codigoParaComponente" />
            </div>
        </div>

        <div class="col-md-6">
            <h4>2. Lista de Referencia</h4>
            <EstadoComponente CodigoEstado="200" />
            <EstadoComponente CodigoEstado="404" />
            <EstadoComponente CodigoEstado="500" />
            <EstadoComponente CodigoEstado="0" />
        </div>
    </div>
</div>

@code {
    private int valorInput = 200; // Lo que el usuario escribe
    private int codigoParaComponente = 200; // Lo que el componente muestra

    private void ActualizarVisor()
    {
        // Al hacer clic, pasamos el valor del input al componente
        codigoParaComponente = valorInput;
    }
}