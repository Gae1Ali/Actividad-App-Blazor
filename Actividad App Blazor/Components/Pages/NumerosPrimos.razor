@page "/numeros-primos"
@rendermode InteractiveServer
<h3>Números primos</h3>

<div class="mb-3">
    <label>Número entero</label>
    <input type="number" class="form-control" @bind="numero" />
</div>

<button class="btn btn-primary" @onclick="GenerarPrimos">
    Generar primos
</button>

<br /> <br />

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-warning">@mensaje</div>
}

<h4>Números primos</h4>

@if (primos.Count > 0)
{
    @foreach (var n in primos)
    {
        <div class="form-control mb-2">@n</div>
    }
}

@code {
    int numero;
    List<int> primos = new List<int>();
    string mensaje = "";

    void GenerarPrimos()
    {
        primos.Clear();
        mensaje = "";

        if (numero < 2)
        {
            mensaje = "No hay números primos menores que 2.";
            return;
        }

        for (int i = 2; i <= numero; i++)
        {
            if (EsPrimo(i))
            {
                primos.Add(i);
            }
        }

        if (primos.Count == 0)
        {
            mensaje = "No se encontraron números primos.";
        }
    }

    bool EsPrimo(int n)
    {
        if (n < 2) return false;

        for (int i = 2; i <= Math.Sqrt(n); i++)
        {
            if (n % i == 0)
                return false;
        }

        return true;
    }
}