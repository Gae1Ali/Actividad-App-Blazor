@page "/lista-numeros"
@rendermode InteractiveServer
<h3>Listas de números</h3>

<div class="mb-3">
    <label>Número 1</label>
    <input type="number" class="form-control" @bind="numero1" />
</div>

<div class="mb-3">
    <label>Número 2</label>
    <input type="number" class="form-control" @bind="numero2" />
</div>

<button class="btn btn-primary" @onclick="Calcular">Calcular</button>

<br /> <br />

<div class="row">
    <div class="col">
        <h4>Pares</h4>
        @foreach (var n in pares)
        {
            <div class="form-control mb-2">@n</div>
        }
    </div>

    <div class="col">
        <h4>Impares</h4>
        @foreach (var n in impares)
        {
            <div class="form-control mb-2">@n</div>
        }
    </div>
</div>

@code {
    int numero1;
    int numero2;

    List<int> pares = new List<int>();
    List<int> impares = new List<int>();

    void Calcular()
    {
        pares.Clear();
        impares.Clear();

        int inicio = Math.Min(numero1, numero2);
        int fin = Math.Max(numero1, numero2);

        for (int i = inicio; i <= fin; i++)
        {
            if (i % 2 == 0)
                pares.Add(i);
            else
                impares.Add(i);
        }
    }
}